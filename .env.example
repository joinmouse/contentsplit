# Recast Environment Variables

# Lemon Squeezy (for payment)
# 1. Register at https://lemonsqueezy.com
# 2. Create a Store → get Store ID
# 3. Create Products: "Recast Pro" ($9/mo), "Recast Team" ($29/mo)
# 4. Each Product has a Variant → get Variant IDs
# 5. Go to Settings → API → Create API Key
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_PRO=
LEMONSQUEEZY_VARIANT_TEAM=

# App URL (set to your production domain)
NEXT_PUBLIC_APP_URL=https://recast-ai.vercel.app
